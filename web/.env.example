# Predinex Web Application Environment Configuration
# Copy this file to .env.local and update the values as needed

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Network selection - must be either 'mainnet' or 'testnet'
# This determines which network the app connects to
NEXT_PUBLIC_NETWORK=testnet

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Application URL - used for WalletConnect metadata and OG images
# Defaults to https://predinex.app if not set
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect Cloud Project ID
# Required for WalletConnect integration
# Get yours at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Web Push VAPID public key used by PushManager.subscribe.
# Generate a VAPID keypair for your deployment and keep the private key server-side only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Server-side Web Push delivery workers should use matching private values.
# These are intentionally not NEXT_PUBLIC_* and must never be imported by client code.
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Soroban RPC URL - overrides the default RPC endpoint for the selected network
# Defaults: mainnet=https://mainnet.stellar.validationcloud.io/v1/soroban/rpc, testnet=https://soroban-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Soroban Contract ID - the deployed contract on Stellar (C... strkey format)
# Required for the Soroban read/write adapters and activity feed
# Testnet example: CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable debug logging in development
# Set to 'true' to see detailed logs
DEBUG=false

# Feature Flags
# =============================================================================

# Enable dispute mock data in development
# Set to 'true' to show mock dispute data when no real disputes exist
# Set to 'false' or leave unset to show unavailable state when no real disputes exist
NEXT_PUBLIC_ENABLE_DISPUTE_MOCK_DATA=false
