# Note: This file is manually kept in sync with the validation schema in src/env.ts.
# Do not add variables here without also adding them to the schema.
#
# Tier key: [development] = local dev server
#            [preview]     = Vercel PR preview (staging API)
#            [production]  = Vercel production deployment

# [development] http://localhost:3002
# [preview]     set to staging API, e.g. https://api-staging.tariffshield.example
# [production]  set to production API, e.g. https://api.tariffshield.example
NEXT_PUBLIC_API_URL=http://localhost:3002

# [development] [preview] testnet
# [production]  mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# [development] local contract address from deploy script
# [preview]     staging contract address
# [production]  production contract address
NEXT_PUBLIC_CONTRACT_ID=CBLASRVG7NRAFP2CDPVSF4WTJBKC6L4FKT2XHR3OH7CLICUBPVQ4PBBF
