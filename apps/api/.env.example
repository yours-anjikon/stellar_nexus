# Note: This file is manually kept in sync with the validation schema in src/config/env.ts.
# Do not add variables here without also adding them to the schema.
# See docs/environment-variables.md for full descriptions of every variable.
#
# Tier key: [Required] = must be set before the server will start
#            [Optional] = has a safe default; override as needed

# ── Database ──────────────────────────────────────────────────────────────────
# [Required] PostgreSQL connection string. NEVER commit a production value.
DATABASE_URL=postgres://tariffshield:tariffshield_dev_password@localhost:5443/tariffshield

# ── API server ────────────────────────────────────────────────────────────────
# [Optional] Port the Express server listens on (default: 3002)
PORT=3002
# [Optional] Application environment: development | production | test
NODE_ENV=development
# [Optional] CORS allowed origin for the web frontend (default: http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────
# [Required] HS256 JWT signing secret — minimum 32 chars. Use 64 hex chars in production.
# NEVER commit a real value.
JWT_SECRET=replace-with-64-hex-chars

# ── Stellar network ───────────────────────────────────────────────────────────
# [Optional] testnet | public (default: testnet)
STELLAR_NETWORK=testnet
# [Required] Soroban RPC endpoint URL
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# [Required] Stellar Horizon REST API endpoint URL
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# [Required] Must match STELLAR_NETWORK. Testnet: "Test SDF Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Platform & surety keypairs (NEVER commit real values) ────────────────────
# [Required] Platform admin Stellar secret key (signs register_importer, set_required_collateral)
PLATFORM_STELLAR_SECRET=
# [Optional] Second admin secret for multi-sig contract upgrade proposals
ADMIN_2_SECRET=
# [Optional] Third admin secret for multi-sig contract upgrade proposals
ADMIN_3_SECRET=
# [Required] Surety Stellar secret key (signs clawback transactions)
SURETY_STELLAR_SECRET=
# [Optional] Separate oracle-role secret (#339). Falls back to PLATFORM_STELLAR_SECRET if unset.
ORACLE_STELLAR_SECRET=

# ── Deployed contract ─────────────────────────────────────────────────────────
# [Required] TariffShield Soroban contract ID (starts with C, 56 chars)
TARIFF_SHIELD_CONTRACT_ID=

# ── Tariff / oracle behaviour ─────────────────────────────────────────────────
# [Optional] block | warn — behaviour when CBP duty rate deviates > 10% (default: block)
CBP_VALIDATION_MODE=block
# [Optional] Percentage change that triggers an oracle alert record (default: 50)
ORACLE_ALERT_THRESHOLD_PCT=50
# [Optional] Alert delivery channel: console (default)
ALERT_CHANNEL=console

# ── Metrics ───────────────────────────────────────────────────────────────────
# [Optional] CIDR block allowed to access GET /metrics. Leave blank to allow all.
METRICS_ALLOWED_CIDR=

# ── SAML 2.0 SSO (all optional — omit to disable SSO endpoints) ──────────────
# SAML_SP_ENTITY_ID=https://tariffshield.io/saml/metadata
# SAML_SP_ACS_URL=https://tariffshield.io/auth/saml/okta/callback
# SAML_SP_PRIVATE_KEY=
# SAML_OKTA_ENTRY_POINT=
# SAML_OKTA_CERT=
# SAML_AZURE_ENTRY_POINT=
# SAML_AZURE_CERT=

# ── DocuSign electronic signatures (all optional — omit to run in stub mode) ──
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
# DOCUSIGN_PRIVATE_KEY=
# DOCUSIGN_WEBHOOK_HMAC_KEY=

# ── Field-level encryption (optional — EIN encryption disabled if unset) ──────
# [Optional] AES-256-GCM key for encrypting EIN and PII at rest. Min 32 chars.
# FIELD_ENCRYPTION_KEY=
# [Optional] Active key version; increment on rotation (default: 1)
# FIELD_ENCRYPTION_KEY_VERSION=1

# ── S3 document storage (optional — KYC/report upload disabled if unset) ──────
# S3_KYC_BUCKET=tariffshield-kyc-dev
# S3_REPORTS_BUCKET=tariffshield-reports-dev
# [Optional] AWS region for S3/KMS (default: us-east-1)
# AWS_REGION=us-east-1

# ── Notifications (optional — email alerts disabled if unset) ─────────────────
# SENDGRID_API_KEY=
# REPORT_FROM_EMAIL=reports@tariffshield.io

# ── Soroban RPC debug logging (development only) ──────────────────────────────
# Enables verbose logging for all contract RPC requests and responses
# Activates if DEBUG=soroban:* or SOROBAN_DEBUG=true (with LOG_LEVEL=debug)
DEBUG=soroban:*
SOROBAN_DEBUG=true
# Formats Soroban debug logs with indentation for readability (default: false)
SOROBAN_LOG_PRETTY=true
