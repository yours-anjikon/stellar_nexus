              "raw": "{{base_url}}/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"importer@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"importer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Register a new user account. `role` defaults to `importer`; use `surety_admin` for surety company accounts (requires license verification before operational routes are available)."
