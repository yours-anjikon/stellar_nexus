# Copy to .env and fill in. Never commit .env.

# Postgres
DATABASE_URL=postgres://tariffshield:tariffshield_dev_password@localhost:5443/tariffshield

# API
PORT=3002
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=replace-with-64-hex-chars

# Stellar testnet
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Platform keypair (funded via friendbot — see scripts/seed.ts)
PLATFORM_STELLAR_SECRET=
PLATFORM_STELLAR_PUBLIC=

# Mock surety keypair (admin of the contract)
SURETY_STELLAR_SECRET=
SURETY_STELLAR_PUBLIC=

# USDC asset (testnet USDC issued by platform for the demo)
USDC_ISSUER_SECRET=
USDC_ISSUER_PUBLIC=

# Deployed contract ID — populated by scripts/deploy-contracts.ts
TARIFF_SHIELD_CONTRACT_ID=

# Render Deployment Hook
RENDER_DEPLOY_HOOK_URL=
RENDER_SERVICE_ID=
